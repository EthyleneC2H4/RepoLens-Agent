# RepoLens Agent local model configuration
# Prerequisite: install Ollama and run `ollama pull qwen3.5:4b`.
# Copy this file to .env. Ollama ignores the API key, but HelloAgents requires
# a non-empty value, so the conventional placeholder `ollama` is used.

LLM_MODEL_ID=qwen3.5:4b
LLM_API_KEY=ollama
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_TIMEOUT=120

# Optional search providers
# TAVILY_API_KEY=tvly-your-tavily-key
# SERPAPI_API_KEY=your-serpapi-key

# Optional Qdrant configuration
QDRANT_URL=https://your-cluster.qdrant.tech:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=hello_agents_vectors
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30

# Optional Neo4j configuration
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# Optional embedding and external-service configuration
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=
EMBED_API_KEY=
EMBED_BASE_URL=
GITHUB_PERSONAL_ACCESS_TOKEN=
HF_TOKEN=
